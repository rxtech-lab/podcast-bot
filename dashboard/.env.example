# RxAuth (OIDC) — register a confidential client in rxlab-auth and copy here.
AUTH_ISSUER=http://localhost:3000
AUTH_CLIENT_ID=debate-bot-dashboard
AUTH_CLIENT_SECRET=replace-with-hashed-client-secret
# NextAuth session secret (any long random string): openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3001

# The debate-bot Go engine (must be started in video mode).
ENGINE_BASE_URL=http://localhost:8080
# Shared service token the engine accepts as `Authorization: Bearer <token>`.
# Set the SAME value as DASHBOARD_SERVICE_TOKEN in the engine's environment.
DASHBOARD_SERVICE_TOKEN=replace-with-shared-service-token

# Turso (libSQL) — create a db with `turso db create` and copy the URL + token.
TURSO_CONNECTION_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
