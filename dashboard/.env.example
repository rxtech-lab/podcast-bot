# RxAuth (OIDC) — register a confidential client in rxlab-auth and copy here.
# Create an "admin" role for this client and assign it to operator users, or the
# admin API returns 403.
AUTH_ISSUER=http://localhost:3000
AUTH_CLIENT_ID=debate-bot-dashboard
AUTH_CLIENT_SECRET=replace-with-hashed-client-secret
# NextAuth session secret (any long random string): openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3001

# The debate-bot Go engine (started in dashboard mode). The admin API is mounted
# at ${ENGINE_BASE_URL}/admin; the signed-in user's rxlab access token is
# forwarded as the bearer, so the engine must have AUTH_ISSUER set and
# ADMIN_ALLOWED_CLIENT_IDS include the AUTH_CLIENT_ID above.
ENGINE_BASE_URL=http://localhost:8080
