// Release.xcconfig — production.
// Points the app at the deployed debate-bot engine.

// Include secrets if available (gitignored).
#include? "Secrets.xcconfig"

// RevenueCat public SDK API key for production builds.
REVENUECAT_API_KEY = $(REVENUECAT_API_KEY_PROD)

// Backend engine base URL (no trailing slash). AppConfig appends paths.
AppAPIBaseURL = https:/$()/server.podcast.rxlab.app

// rxlab OAuth (RxAuthSwift).
AppAuthIssuer = https:/$()/auth.rxlab.app
AppAuthClientID = client_a22a1a75102a4279bcb893f437e74027
AppAuthRedirectURI = debatepod:/$()/oauth-callback
AppAuthScopes = openid
APS_ENVIRONMENT = production
