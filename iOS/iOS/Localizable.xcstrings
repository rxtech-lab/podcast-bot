    "Anyone with the link can join and comment until it expires (max 3 days). You can revoke a link any time." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任何拥有链接的人都可以在链接过期前加入并评论（最多 3 天）。你可以随时撤销链接。"
          }
        },
        "zh-Hant-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任何擁有連結的人都可以在連結過期前加入並留言（最多 3 日）。你可以隨時撤銷連結。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "任何擁有連結的人都可以在連結過期前加入並留言（最多 3 天）。你可以隨時撤銷連結。"
          }
        }
      }
    },
