.env
bin
mcp.json
out
.DS_Store
frontend/node_modules
frontend/dist
internal/server/web-dist
*.png
.playwright-mcp
topics/*.md
!internal/video/assets/*.png
# Golden style-test reference frames must be committed (override *.png above).
# The _actual/ dump written on a failing run stays ignored.
!smoke-test/**/*.png
smoke-test/_actual/
# Style-test CJK font is fetched on demand (scripts/fetch-style-font.sh), not committed.
internal/video/testdata/fonts/*.otf
gen-assets
channels
# Root-level compiled binaries only — anchored with a leading slash so these
# patterns don't also match the cmd/<name>/ source directories (an unanchored
# "debate-bot" silently ignored every .go file under cmd/debate-bot/).
/debate-bot
/music-smoke
/transition-smoke
/series-smoke
/series-recap-smoke
/discussion-smoke

# k8s filled-in secrets (never commit)
k8s/secrets.yaml
*.xcuserstate
