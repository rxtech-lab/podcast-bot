# OpenAI-compatible endpoint shared by host + every agent (overrideable per-agent in topic.md).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
HOST_MODEL=gpt-4o

# Separate compression model. Used to summarise per-agent memory.md when it grows past a token threshold.
# Endpoint/key default to OPENAI_BASE_URL/OPENAI_API_KEY when blank.
COMPRESSION_BASE_URL=
COMPRESSION_API_KEY=
COMPRESSION_MODEL=gpt-4o-mini

# Azure Cognitive Services Speech (TTS).
AZURE_SPEECH_KEY=replace-me
AZURE_SPEECH_REGION=eastus

# Where audio segments, the combined debate.mp3, transcript.txt, memory/, and run.log are written.
OUT_DIR=./out
