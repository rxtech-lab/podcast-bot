# OpenAI-compatible endpoint shared by host + every agent (overrideable per-agent in topic.md).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
HOST_MODEL=gpt-4o

# Optional: dedicated model for the puzzle visual director (one call per
# puzzle, plans surface + conclusion image beats). Defaults to HOST_MODEL.
# A stronger model here improves story-beat ordering and frame variety.
SCENE_PLANNER_MODEL=

# Separate compression model. Used to summarise per-agent memory.md when it grows past a token threshold.
# Endpoint/key default to OPENAI_BASE_URL/OPENAI_API_KEY when blank.
COMPRESSION_BASE_URL=
COMPRESSION_API_KEY=
COMPRESSION_MODEL=gpt-4o-mini

# Azure Cognitive Services Speech (TTS).
AZURE_SPEECH_KEY=replace-me
AZURE_SPEECH_REGION=eastus

# Where audio segments, the combined debate.mp3, transcript.txt, memory/, and run.log are written.
OUT_DIR=./out

# Optional S3-compatible storage for finished media. Cloudflare R2 uses
# S3_REGION=auto and S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com.
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_PREFIX=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional public/custom download domain. When set, download URLs use this
# base URL instead of presigned S3 URLs.
S3_DOWNLOAD_BASE_URL=
